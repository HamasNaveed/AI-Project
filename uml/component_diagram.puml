@startuml component_diagram
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam component {
    BackgroundColor White
    BorderColor #555
    ArrowColor #333
    FontSize 12
}
skinparam package {
    BackgroundColor #F0F0F8
    BorderColor #8888CC
    FontStyle bold
}
skinparam interface {
    BackgroundColor #FFFFE0
    BorderColor #AAAA00
}
skinparam note {
    BackgroundColor #FFFDE0
    BorderColor #CCAA00
}

title "Dungeon RPG AI — Component / Package Diagram\n(AI2002 Part B)"

' ─────────────────────────────────────────────────
' Main Application Module
' ─────────────────────────────────────────────────
package "dungeon_rpg_ai_enhanced.py" as APP {

    package "Presentation & Orchestration" as PRES_PKG #E8F4FF {
        component [Game Entry Point\nmain()\n5 modes: Play / Boss Rush / Auto / Metrics] as MAIN
        component [Player Input Handler\nget_player_action()] as INPUT
        component [Combat Loop Manager\nrun_combat() : bool] as COMBAT
        component [Boss Rush Controller\nrun_boss_rush()\ngenerate_boss()] as BOSSRUSH
        component [Output Formatter\nprint_header()\ndescribe_action()\ndivider()] as OUTPUT
    }

    package "AI Decision Engine" as AI_PKG #FFF4E0 {
        component [Minimax Search\nminimax()] as MINIMAX
        component [AI Action Selector\nai_choose_action()] as SELECTOR
        component [Heuristic Evaluator\nheuristic()] as HEUR
    }

    package "Behaviour Analysis" as BEHAV_PKG #E8FFE8 {
        component [Reputation System\nReputationSystem] as REP
        component [Pattern Analyzer\nPatternAnalyzer\n<<Strategy>>] as PAT
        component [Optimization Metrics\nOptimizationMetrics] as METRICS
    }

    package "Simulation Engine" as SIM_PKG #FFE8F0 {
        component [Turn Simulator\nsimulate_turn()] as SIM
        component [Action Validator\ncan_perform()\navailable_actions()] as AVAIL
    }

    package "Game State & Constants" as STATE_PKG #F0F0F0 {
        component [Combatant State\nCombatantState] as CS
        component [Game Constants\nACTIONS\nACTION_STAMINA_COST\nACTION_DAMAGE\nREST_RECOVERY] as CONST
    }
}

' ─────────────────────────────────────────────────
' External Dependencies (Python Stdlib only)
' ─────────────────────────────────────────────────
package "Python Standard Library" as STDLIB {
    component [collections\nCounter] as COLL
    component [copy\n(list.copy)] as COPY
    component [random\nrandom.choices] as RAND
    component [typing\nList, Dict, Tuple\nOptional] as TYPING
}

' ─────────────────────────────────────────────────
' Test Module
' ─────────────────────────────────────────────────
package "test_dungeon_rpg.py" as TEST_PKG #F8F8FF {
    component [Unit Tests\nunittest.TestCase] as TESTS
    component [Integration Tests\nTestIntegration] as ITESTS
    component [Performance Tests\nTestPerformance] as PTESTS
    component [Boss Tests\nTestBossGeneration\nTestBossRush] as BOSSTESTS
}

' ─────────────────────────────────────────────────
' Internal Interfaces (dependency arrows)
' ─────────────────────────────────────────────────

' Orchestration flows
MAIN      --> COMBAT    : modes 1,3,4 — single combat
MAIN      --> BOSSRUSH  : modes 2,5 — boss rush loop
BOSSRUSH  --> COMBAT    : calls run_combat() per level\nreturns bool (won?)
COMBAT    --> INPUT     : calls on human turn
COMBAT    --> OUTPUT    : logs each action
COMBAT    --> SELECTOR  : requests AI action
COMBAT    --> SIM       : applies player action

' AI Decision chain
SELECTOR --> MINIMAX  : calls with depth, α, β
MINIMAX  --> HEUR     : evaluates leaf nodes
MINIMAX  --> SIM      : simulate_turn() per search node
MINIMAX  --> AVAIL    : available_actions()
MINIMAX  --> METRICS  : record_node() (optional)
HEUR     --> REP      : aggression_ratio()\nevil_ratio()
HEUR     --> PAT      : predictability_score()\ncyclic/repeat detection

' Simulation reads state and constants
SIM   --> CS    : clone() then apply
SIM   --> CONST : reads ACTION_DAMAGE\nSTAMINA_COST
AVAIL --> CS    : reads stamina
AVAIL --> CONST : reads ACTION_STAMINA_COST

' Behaviour reads player history
REP --> CS : reads action from call arg
PAT --> CS : reads action_history list

' Combat loop creates all components
COMBAT --> REP     : record_action() each turn
COMBAT --> CS      : creates Player & Enemy
COMBAT --> METRICS : creates if track_metrics=True
COMBAT --> PAT     : creates PatternAnalyzer

' Stdlib dependencies
PAT    ..> COLL  : Counter for frequency_analysis
CS     ..> COPY  : list.copy() in clone()
COMBAT ..> RAND  : random.choices() for auto-sim
APP    ..> TYPING : type annotations throughout

' Test dependencies
TESTS     ..> APP    : imports all public symbols
ITESTS    ..> RAND   : random.choice() in simulation
PTESTS    ..> MINIMAX: benchmarks depth=3 search
BOSSTESTS ..> BOSSRUSH : tests generate_boss()\nand run_boss_rush() auto-sim

note bottom of PAT
  <b>Strategy Pattern</b>
  PatternAnalyzer is injected into
  heuristic() and minimax() as an
  optional parameter — can be swapped
  or omitted without breaking the system.
end note

note bottom of METRICS
  <b>Optional Observer</b>
  Only created when track_metrics=True.
  Passed through minimax() call chain
  to record pruning efficiency.
end note

note bottom of STDLIB
  <b>No external packages required.</b>
  Pure Python stdlib implementation.
  Install: none needed.
end note

@enduml
